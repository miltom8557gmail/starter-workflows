<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:padding="20dp">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NEXUS COMMAND"
        android:textColor="#00E6FF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerInParent="true">

        <Button
            android:id="@+id/btn_social"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🌐 CONECTAR REDES SOCIAIS"
            android:backgroundTint="#1A1A1A"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/btn_auto"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="⚡ ATIVAR AUTOMAÇÃO (BOT)"
            android:backgroundTint="#00FF41"
            android:textColor="#000000"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:id="@+id/log_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Sistema em Espera..."
            android:textColor="#555555"
            android:gravity="center"
            android:textSize="14sp"/>
    </LinearLayout>

</RelativeLayout>
