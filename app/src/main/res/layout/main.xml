<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505"
    android:padding="25dp">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NEXUS COMMAND"
        android:textColor="#00FFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="50dp"
        android:shadowColor="#00FFFF"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="15"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerInParent="true">

        <Button
            android:id="@+id/btn_social"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="🌐 LINK SYNC: REDES"
            android:backgroundTint="#111111"
            android:textColor="#00FFFF"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btn_auto"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="⚡ INICIAR BOT SOBERANO"
            android:backgroundTint="#00FF41"
            android:textColor="#000000"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/log_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SISTEMA: VIGILANTE"
            android:textColor="#444444"
            android:gravity="center"
            android:textSize="12sp"
            android:letterSpacing="0.2"/>
    </LinearLayout>
</RelativeLayout>
