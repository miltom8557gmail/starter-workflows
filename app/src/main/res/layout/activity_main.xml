<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:id="@+id/pin_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="30dp"
        android:background="#000"
        android:elevation="10dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AKAME SECURE ACCESS"
            android:textColor="#FF0000"
            android:textStyle="bold"
            android:textSize="22sp" />
        <EditText
            android:id="@+id/et_pin_entry"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="PIN ou Chave Mestra"
            android:textColorHint="#444"
            android:textColor="#FFF"
            android:textAlignment="center"
            android:inputType="textPassword"
            android:layout_marginTop="30dp"
            android:backgroundTint="#FF0000" />
        <Button
            android:id="@+id/btn_unlock"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="DESBLOQUEAR"
            android:backgroundTint="#FF0000"
            android:textColor="#FFF"
            android:layout_marginTop="20dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A1A"
            app:tabTextColor="#888"
            app:tabSelectedTextColor="#FF0000" />

        <LinearLayout
            android:id="@+id/chat_interface"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#0A0A0A"
            android:visibility="gone"
            android:padding="10dp">
            <TextView
                android:id="@+id/chat_target_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seraphina Vale"
                android:textColor="#FFD700"
                android:textStyle="bold" />
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/chat_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFF"
                    android:textSize="16sp"
                    android:text="Seraphina: 'O que fazes aqui tão tarde? Estás à procura de problemas... ou de mim?'\n\n" />
            </ScrollView>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <EditText
                    android:id="@+id/et_message"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Escrever..."
                    android:textColor="#FFF"
                    android:textColorHint="#555" />
                <Button
                    android:id="@+id/btn_send"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENVIAR"
                    android:backgroundTint="#FF0000" />
            </LinearLayout>
            <Button
                android:id="@+id/btn_close_chat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sair"
                android:backgroundTint="#444"
                android:layout_gravity="center" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/dashboard_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <TextView
                    android:id="@+id/aba_titulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESCOBRIR"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_personagem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#1A1A1A">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="15dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Seraphina Vale"
                            android:textColor="#FFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Boneca de porcelana com veneno sob a pele. Obsessão corrosiva."
                            android:textColor="#888"
                            android:textSize="13sp" />
                        <Button
                            android:id="@+id/btn_interagir"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="INICIAR ROLEPLAY"
                            android:backgroundTint="#FFD700"
                            android:textColor="#000"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <ListView
                    android:id="@+id/listView_logs"
                    android:layout_width="match_parent"
                    android:layout_height="400dp"
                    android:layout_marginTop="20dp" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</RelativeLayout>
