<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:id="@+id/pin_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="30dp"
        android:background="#000"
        android:elevation="10dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AKAME SECURE ACCESS"
            android:textColor="#FF0000"
            android:textStyle="bold"
            android:textSize="22sp" />
        <EditText
            android:id="@+id/et_pin_entry"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="PIN ou Chave Mestra"
            android:textColorHint="#444"
            android:textColor="#FFF"
            android:textAlignment="center"
            android:inputType="textPassword"
            android:layout_marginTop="30dp"
            android:backgroundTint="#FF0000" />
        <Button
            android:id="@+id/btn_unlock"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="DESBLOQUEAR"
            android:backgroundTint="#FF0000"
            android:textColor="#FFF"
            android:layout_marginTop="20dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A1A"
            app:tabTextColor="#888"
            app:tabSelectedTextColor="#FF0000" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            
            <LinearLayout
                android:id="@+id/container_dinamico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/aba_titulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESCOBRIR 18+"
                    android:textColor="#FFD700"
                    android:textStyle="bold"
                    android:textSize="24sp" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_personagem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="15dp"
                    app:cardBackgroundColor="#1A1A1A">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="15dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Seraphina Vale"
                            android:textColor="#FFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Boneca de porcelana com veneno sob a pele. Obsessão corrosiva e manipulação calculada."
                            android:textColor="#AAA"
                            android:textSize="14sp"
                            android:layout_marginTop="5dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NSFW" android:textColor="#FF0000" android:textSize="10sp" android:padding="4dp" android:background="#33FF0000" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Manipuladora" android:textColor="#FFD700" android:textSize="10sp" android:layout_marginStart="5dp" android:padding="4dp" android:background="#33FFD700" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/btn_interagir"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:text="INICIAR HISTÓRIA"
                            android:backgroundTint="#FFD700"
                            android:textColor="#000"
                            android:textStyle="bold"
                            android:layout_marginTop="15dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <ListView
                    android:id="@+id/listView_logs"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="20dp"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</RelativeLayout>
