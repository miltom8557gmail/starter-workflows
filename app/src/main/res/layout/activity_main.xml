<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:id="@+id/pin_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="30dp"
        android:background="#000"
        android:elevation="10dp"
        android:visibility="visible">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AKAME SECURE ACCESS"
            android:textColor="#FF0000"
            android:textStyle="bold"
            android:textSize="22sp" />

        <EditText
            android:id="@+id/et_pin_entry"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="PIN ou Chave Mestra"
            android:textColorHint="#444"
            android:textColor="#FFF"
            android:textAlignment="center"
            android:inputType="textPassword"
            android:layout_marginTop="30dp"
            android:backgroundTint="#FF0000" />

        <Button
            android:id="@+id/btn_unlock"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="DESBLOQUEAR"
            android:backgroundTint="#FF0000"
            android:textColor="#FFF"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A1A"
            app:tabTextColor="#888"
            app:tabSelectedTextColor="#FF0000" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/aba_titulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEGURANÇA ATIVA"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_acao_principal"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="🛡️ LIMPAR EXIF (GALERIA)"
                android:backgroundTint="#FFD700"
                android:textColor="#000"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <ListView
                android:id="@+id/listView_logs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="15dp" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
