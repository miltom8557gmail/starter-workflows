    print(f"✅ [AKAME FACTORY]: Estrutura para '{app_name}' forjada em {base_path}")

if __name__ == "__main__":
    if len(sys.argv) > 2:
        create_client_project(sys.argv[1], sys.argv[2])
    else:
        print("❌ Uso: python3 app_factory.py 'Nome do App' 'Descrição/Tema'")
EOF

